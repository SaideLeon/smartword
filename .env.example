# GEMINI_API_KEY: Required for all school generation/chat flows via Gemini SDK
# (single key or comma-separated keys).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required only for audio transcription (/api/transcribe).
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Upstash Redis: Required in production for distributed/persistent rate limiting.
UPSTASH_REDIS_REST_URL="https://<your-upstash-endpoint>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"

# Export endpoint payload limit in bytes (default: 500000)
EXPORT_MAX_CONTENT_BYTES="500000"

# PaySuite: integração automática de pagamentos (/api/payment e /api/payment/webhook)
PAYSUITE_API_TOKEN="YOUR_PAYSUITE_API_TOKEN"
PAYSUITE_WEBHOOK_SECRET="YOUR_PAYSUITE_WEBHOOK_SECRET"
# Opcional: usar sandbox/base URL custom
PAYSUITE_API_BASE_URL="https://paysuite.tech/api/v1"

# Necessário para processar confirmações automáticas de pagamento via webhook
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
