# GEMINI_API_KEY: Required for all school generation/chat flows via Gemini SDK
# (single key or comma-separated keys).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Required only for audio transcription (/api/transcribe).
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Upstash Redis: Required in production for distributed/persistent rate limiting.
UPSTASH_REDIS_REST_URL="https://<your-upstash-endpoint>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REDIS_REST_TOKEN"
